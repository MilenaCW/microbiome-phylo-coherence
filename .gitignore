# GG2 backbone — copied locally but too large to commit (see README for download)
greengenes/

# Raw sequencing data (FASTQ files)
soil/data/downloaded_data/
ocean/data/downloaded_data/

# Large intermediate processing outputs (DADA2, GG2 pipelines)
# processed_data/environmental/ is intentionally NOT excluded (small CSVs)
# Only GG2/0.90/final/{tree.nwk,taxonomy.csv} and GG2/summary_diagnostics/gg2_sweep_summary.tsv
# are kept — needed by plot_abu_loadings.R and SI_GG2_performance.R (PERC=0.90 in run_all_plots.sh)
soil/data/processed_data/16S/DADA/
ocean/data/processed_data/16S/DADA/
soil/data/processed_data/16S/GG2/input/
ocean/data/processed_data/16S/GG2/input/
soil/data/processed_data/16S/GG2/*/intermediate/
ocean/data/processed_data/16S/GG2/*/intermediate/
soil/data/processed_data/16S/GG2/*/diagnostics/
ocean/data/processed_data/16S/GG2/*/diagnostics/
soil/data/processed_data/16S/GG2/*/final/seqtab*
ocean/data/processed_data/16S/GG2/*/final/seqtab*
soil/data/processed_data/16S/GG2/*/final/dna-sequences.fasta
ocean/data/processed_data/16S/GG2/*/final/dna-sequences.fasta
soil/data/processed_data/16S/GG2/0.8[0-9]/final/
ocean/data/processed_data/16S/GG2/0.8[0-9]/final/
soil/data/processed_data/16S/GG2/0.9[1-9]/final/
ocean/data/processed_data/16S/GG2/0.9[1-9]/final/
soil/data/processed_data/16S/GG2/summary_diagnostics/*.jpg
ocean/data/processed_data/16S/GG2/summary_diagnostics/*.jpg

